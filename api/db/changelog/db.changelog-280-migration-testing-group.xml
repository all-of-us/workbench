<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">
    <changeSet author="dolbeew" id="changelog-280-migration-testing-group">
        <createTable tableName="migration_testing_group">
            <column name="migration_testing_group_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseColumnNames="user_id"
          baseTableName="migration_testing_group"
          constraintName="fk_migration_testing_user_id"
          referencedColumnNames="user_id"
          referencedTableName="user" onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>
